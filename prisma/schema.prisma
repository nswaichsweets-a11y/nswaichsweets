generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRoleKey {
  SUPER_ADMIN
  OWNER
  MANAGER
  CASHIER
  INVENTORY_STAFF
  ACCOUNTANT
  READ_ONLY_STAFF
}

enum Unit {
  KG
  GRAM
  PIECE
  BOX
  LITRE
  PACKET
}

enum PaymentMode {
  CASH
  UPI
  CARD
  BANK
  CREDIT
  MIXED
  OTHER
}

enum InvoiceStatus {
  PAID
  PARTIAL
  UNPAID
  CANCELLED
}

enum LedgerOwnerType {
  CUSTOMER
  FARMER
  SUPPLIER
}

enum LedgerEntryType {
  CREDIT
  DEBIT
}

enum InventoryItemType {
  RAW_MATERIAL
  FINISHED_PRODUCT
  PACKAGING
  DISPOSABLE
  SHOP_SUPPLY
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
  WASTAGE
  SPOILAGE
  TRANSFER
}

enum MilkSession {
  MORNING
  EVENING
}

enum SalaryType {
  MONTHLY
  DAILY
  HOURLY
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LEAVE
}

enum PaymentDirection {
  IN
  OUT
}

enum PaymentFor {
  CUSTOMER
  FARMER
  SUPPLIER
  EMPLOYEE
  EXPENSE
  INVOICE
}

enum ReportFormat {
  PDF
  CSV
  EXCEL
}

enum BulkOrderStatus {
  ENQUIRY
  CONFIRMED
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

model Role {
  id          String      @id @default(cuid())
  key         UserRoleKey @unique
  name        String
  description String?
  users       User[]
  permissions Permission[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Permission {
  id          String   @id @default(cuid())
  code        String   @unique
  label       String
  module      String
  description String?
  roles       Role[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([module])
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  phone         String?
  googleSubject String?
  passwordHash  String
  roleId        String
  role          Role      @relation(fields: [roleId], references: [id])
  active        Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  invoices      Invoice[] @relation("InvoiceCashier")
  payments      Payment[] @relation("PaymentCreator")
  auditLogs     AuditLog[]
  reportExports ReportExportLog[]
  stockMoves    StockMovement[]
  passwordResetTokens PasswordResetToken[]

  @@index([roleId])
  @@index([active])
  @@index([email])
  @@index([googleSubject])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@index([usedAt])
}

model BusinessSettings {
  id                  String   @id @default(cuid())
  businessName        String   @default("Namdhari Swaich Sweets")
  logoUrl             String?
  address             String   @default("")
  phone               String   @default("")
  whatsappNumber      String?
  email               String?
  gstin               String?
  fssaiLicense        String?
  registeredNumber    String?
  invoicePrefix       String   @default("NSS")
  invoiceFooterTerms  String   @default("Thank you for your business.")
  invoiceAssignees    String?
  upiPaymentDetails   String?
  currency            String   @default("INR")
  taxInclusive        Boolean  @default(false)
  defaultTaxRate      Decimal  @default(0) @db.Decimal(5, 2)
  themeColor          String   @default("#141b18")
  branchName          String?
  branchCode          String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Product {
  id                 String        @id @default(cuid())
  name               String
  category           String
  sku                String        @unique
  unit               Unit
  sellingPrice       Decimal       @db.Decimal(12, 2)
  costPrice          Decimal       @default(0) @db.Decimal(12, 2)
  taxRate            Decimal       @default(0) @db.Decimal(5, 2)
  imageUrl           String?
  active             Boolean       @default(true)
  wholesalePrice     Decimal?      @db.Decimal(12, 2)
  festivalPrice      Decimal?      @db.Decimal(12, 2)
  lowStockThreshold  Decimal?      @db.Decimal(12, 3)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  invoiceItems       InvoiceItem[]
  inventoryItems     InventoryItem[]

  @@index([name])
  @@index([category])
  @@index([sku])
  @@index([active])
}

model Customer {
  id             String        @id @default(cuid())
  name           String
  phone          String
  address        String?
  email          String?
  notes          String?
  openingBalance Decimal       @default(0) @db.Decimal(12, 2)
  active         Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  invoices       Invoice[]
  payments       Payment[]
  ledgerEntries  LedgerEntry[]

  @@index([name])
  @@index([phone])
  @@index([active])
}

model Supplier {
  id             String          @id @default(cuid())
  name           String
  contactPerson  String?
  phone          String
  alternatePhone String?
  whatsappNumber String?
  address        String?
  email          String?
  gstOrLicense   String?
  supplyCategories String?
  paymentTerms   String?
  bankDetails    String?
  notes          String?
  openingBalance Decimal         @default(0) @db.Decimal(12, 2)
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  payments       Payment[]
  ledgerEntries  LedgerEntry[]
  inventoryItems InventoryItem[]
  stockMoves     StockMovement[]

  @@index([name])
  @@index([phone])
  @@index([active])
}

model Farmer {
  id             String           @id @default(cuid())
  name           String
  phone          String
  villageAddress String?
  paymentDetails String?
  notes          String?
  openingBalance Decimal          @default(0) @db.Decimal(12, 2)
  active         Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  milkCollections MilkCollection[]
  payments       Payment[]
  ledgerEntries  LedgerEntry[]

  @@index([name])
  @@index([phone])
  @@index([active])
}

model Invoice {
  id            String         @id @default(cuid())
  invoiceNumber String         @unique
  shareToken    String?
  customerId    String?
  customer      Customer?      @relation(fields: [customerId], references: [id])
  issueDate     DateTime       @default(now())
  subtotal      Decimal        @default(0) @db.Decimal(12, 2)
  discountTotal Decimal        @default(0) @db.Decimal(12, 2)
  taxTotal      Decimal        @default(0) @db.Decimal(12, 2)
  total         Decimal        @default(0) @db.Decimal(12, 2)
  paidAmount    Decimal        @default(0) @db.Decimal(12, 2)
  dueAmount     Decimal        @default(0) @db.Decimal(12, 2)
  paymentMode   PaymentMode    @default(CASH)
  status        InvoiceStatus  @default(UNPAID)
  notes         String?
  cancelReason  String?
  cancelledAt   DateTime?
  assignedToName String?
  cashierId     String?
  cashier       User?          @relation("InvoiceCashier", fields: [cashierId], references: [id])
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  items         InvoiceItem[]
  payments      Payment[]
  ledgerEntries LedgerEntry[]

  @@index([invoiceNumber])
  @@index([shareToken])
  @@index([customerId])
  @@index([issueDate])
  @@index([status])
  @@index([paymentMode])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id])
  productName String
  quantity    Decimal  @db.Decimal(12, 3)
  unit        Unit
  price       Decimal  @db.Decimal(12, 2)
  discount    Decimal  @default(0) @db.Decimal(12, 2)
  taxRate     Decimal  @default(0) @db.Decimal(5, 2)
  taxAmount   Decimal  @default(0) @db.Decimal(12, 2)
  lineTotal   Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([invoiceId])
  @@index([productId])
}

model Payment {
  id              String           @id @default(cuid())
  paymentFor      PaymentFor
  direction       PaymentDirection
  mode            PaymentMode
  amount          Decimal          @db.Decimal(12, 2)
  paymentDate     DateTime         @default(now())
  referenceNumber String?
  notes           String?
  customerId      String?
  customer        Customer?        @relation(fields: [customerId], references: [id])
  farmerId        String?
  farmer          Farmer?          @relation(fields: [farmerId], references: [id])
  supplierId      String?
  supplier        Supplier?        @relation(fields: [supplierId], references: [id])
  employeeId      String?
  employee        Employee?        @relation(fields: [employeeId], references: [id])
  expenseId       String?
  expense         Expense?         @relation(fields: [expenseId], references: [id])
  invoiceId       String?
  invoice         Invoice?         @relation(fields: [invoiceId], references: [id])
  createdById     String?
  createdBy       User?            @relation("PaymentCreator", fields: [createdById], references: [id])
  ledgerEntries   LedgerEntry[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([paymentFor])
  @@index([direction])
  @@index([mode])
  @@index([paymentDate])
  @@index([customerId])
  @@index([farmerId])
  @@index([supplierId])
  @@index([employeeId])
  @@index([invoiceId])
}

model LedgerEntry {
  id               String          @id @default(cuid())
  ownerType        LedgerOwnerType
  entryType        LedgerEntryType
  amount           Decimal         @db.Decimal(12, 2)
  entryDate        DateTime        @default(now())
  description      String
  customerId       String?
  customer         Customer?       @relation(fields: [customerId], references: [id])
  farmerId         String?
  farmer           Farmer?         @relation(fields: [farmerId], references: [id])
  supplierId       String?
  supplier         Supplier?       @relation(fields: [supplierId], references: [id])
  invoiceId        String?
  invoice          Invoice?        @relation(fields: [invoiceId], references: [id])
  paymentId        String?
  payment          Payment?        @relation(fields: [paymentId], references: [id])
  milkCollectionId String?
  milkCollection   MilkCollection? @relation(fields: [milkCollectionId], references: [id])
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([ownerType])
  @@index([entryType])
  @@index([entryDate])
  @@index([customerId])
  @@index([farmerId])
  @@index([supplierId])
}

model InventoryItem {
  id              String            @id @default(cuid())
  name            String
  type            InventoryItemType
  unit            Unit
  currentQuantity Decimal           @default(0) @db.Decimal(12, 3)
  minimumQuantity Decimal           @default(0) @db.Decimal(12, 3)
  costPerUnit     Decimal           @default(0) @db.Decimal(12, 2)
  supplierId      String?
  supplier        Supplier?         @relation(fields: [supplierId], references: [id])
  productId       String?
  product         Product?          @relation(fields: [productId], references: [id])
  batchNumber     String?
  expiryDate      DateTime?
  notes           String?
  active          Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  movements       StockMovement[]

  @@index([name])
  @@index([type])
  @@index([supplierId])
  @@index([productId])
  @@index([active])
}

model StockMovement {
  id               String            @id @default(cuid())
  inventoryItemId  String
  inventoryItem    InventoryItem     @relation(fields: [inventoryItemId], references: [id])
  movementType     StockMovementType
  quantity         Decimal           @db.Decimal(12, 3)
  unitCost         Decimal           @default(0) @db.Decimal(12, 2)
  totalCost        Decimal           @default(0) @db.Decimal(12, 2)
  supplierId       String?
  supplier         Supplier?         @relation(fields: [supplierId], references: [id])
  milkCollectionId String?
  milkCollection   MilkCollection?   @relation(fields: [milkCollectionId], references: [id])
  movementDate     DateTime          @default(now())
  notes            String?
  createdById      String?
  createdBy        User?             @relation(fields: [createdById], references: [id])
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([inventoryItemId])
  @@index([movementType])
  @@index([movementDate])
  @@index([supplierId])
}

model MilkCollection {
  id             String          @id @default(cuid())
  farmerId       String
  farmer         Farmer          @relation(fields: [farmerId], references: [id])
  collectionDate DateTime        @default(now())
  session        MilkSession
  quantityLitres Decimal         @db.Decimal(12, 3)
  fat            Decimal?        @db.Decimal(5, 2)
  snf            Decimal?        @db.Decimal(5, 2)
  ratePerLitre   Decimal         @db.Decimal(12, 2)
  totalAmount    Decimal         @db.Decimal(12, 2)
  paidAmount     Decimal         @default(0) @db.Decimal(12, 2)
  dueAmount      Decimal         @default(0) @db.Decimal(12, 2)
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  ledgerEntries  LedgerEntry[]
  stockMovements StockMovement[]

  @@index([farmerId])
  @@index([collectionDate])
  @@index([session])
}

model Employee {
  id             String          @id @default(cuid())
  name           String
  phone          String
  aadhaarNumber  String          @default("")
  address        String?
  designation    String
  joiningDate    DateTime
  salaryType     SalaryType
  salaryRate     Decimal         @db.Decimal(12, 2)
  active         Boolean         @default(true)
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  attendance     Attendance[]
  salaryPayments SalaryPayment[]
  payments       Payment[]

  @@index([name])
  @@index([phone])
  @@index([aadhaarNumber])
  @@index([designation])
  @@index([active])
}

model Attendance {
  id           String           @id @default(cuid())
  employeeId   String
  employee     Employee         @relation(fields: [employeeId], references: [id])
  date         DateTime
  status       AttendanceStatus
  hoursWorked  Decimal?         @db.Decimal(6, 2)
  notes        String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([employeeId, date])
  @@index([date])
  @@index([status])
}

model SalaryPayment {
  id             String   @id @default(cuid())
  employeeId     String
  employee       Employee @relation(fields: [employeeId], references: [id])
  salaryMonth    DateTime
  baseSalary     Decimal  @db.Decimal(12, 2)
  advance        Decimal  @default(0) @db.Decimal(12, 2)
  bonus          Decimal  @default(0) @db.Decimal(12, 2)
  deduction      Decimal  @default(0) @db.Decimal(12, 2)
  finalPayable   Decimal  @db.Decimal(12, 2)
  paidAmount     Decimal  @default(0) @db.Decimal(12, 2)
  pendingAmount  Decimal  @default(0) @db.Decimal(12, 2)
  paymentDate    DateTime?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([employeeId])
  @@index([salaryMonth])
  @@index([paymentDate])
}

model Expense {
  id              String    @id @default(cuid())
  category        String
  amount          Decimal   @db.Decimal(12, 2)
  paymentMode     PaymentMode
  expenseDate     DateTime  @default(now())
  notes           String?
  receiptUrl      String?
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  payments        Payment[]

  @@index([category])
  @@index([expenseDate])
  @@index([paymentMode])
  @@index([deletedAt])
}

model BulkOrder {
  id              String          @id @default(cuid())
  customerName    String
  phone           String
  occasion        String?
  deliveryDate    DateTime
  deliveryTime    String?
  itemsSummary    String
  quantitySummary String?
  estimatedTotal  Decimal         @default(0) @db.Decimal(12, 2)
  advancePaid     Decimal         @default(0) @db.Decimal(12, 2)
  balanceDue      Decimal         @default(0) @db.Decimal(12, 2)
  status          BulkOrderStatus @default(ENQUIRY)
  assignedToName  String?
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([customerName])
  @@index([phone])
  @@index([deliveryDate])
  @@index([status])
}

model HolidayPlan {
  id              String   @id @default(cuid())
  name            String
  eventDate       DateTime
  category        String?
  demandNotes     String?
  productionNotes String?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([name])
  @@index([eventDate])
  @@index([active])
}

model ReportExportLog {
  id          String       @id @default(cuid())
  reportKey   String
  reportTitle String
  format      ReportFormat
  filters     Json?
  generatedById String?
  generatedBy   User?     @relation(fields: [generatedById], references: [id])
  createdAt   DateTime    @default(now())

  @@index([reportKey])
  @@index([format])
  @@index([createdAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  module      String
  action      String
  recordId    String?
  recordTitle String?
  oldValues   Json?
  newValues   Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([module])
  @@index([action])
  @@index([recordId])
  @@index([createdAt])
}
