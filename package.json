{
  "name": "namdhari-swaich-sweets-suite",
  "version": "0.1.0",
  "private": true,
  "description": "Personalized business management PWA for Namdhari Swaich Sweets.",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "npm run db:generate && next build",
    "start": "next start",
    "setup:local": "node scripts/setup-local-env.mjs && npm run db:push && npm run db:seed",
    "typecheck": "tsc --noEmit",
    "db:generate": "node scripts/prisma-local.mjs generate",
    "db:push": "node scripts/sqlite-local-push.mjs",
    "db:migrate": "node scripts/prisma-local.mjs migrate dev",
    "db:seed": "node scripts/prisma-local.mjs db seed",
    "db:reset-business-data": "node scripts/setup-local-env.mjs && node scripts/run-local.mjs tsx prisma/reset-business-data.ts",
    "backup:cloud": "node scripts/run-local.mjs tsx scripts/google-cloud-backup.ts",
    "postinstall": "node scripts/prisma-local.mjs generate"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.0.1",
    "@prisma/client": "^6.16.2",
    "@radix-ui/react-slot": "^1.1.1",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "16.2.7",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.55.0",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prisma": "^6.16.2",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.9.2"
  }
}
